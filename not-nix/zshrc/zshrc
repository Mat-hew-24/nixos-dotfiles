docktest() {
  local cname=$1
  local image=$2

  if [ -z "$cname" ] || [ -z "$image" ]; then
    echo "Usage: dockrun <container_name> <image>"
    return 1
  fi

  docker run -d --name "$cname" "$image" sleep infinity
}

clone_all_repos() {
	gh repo list --limit 1000 --json nameWithOwner -q '.[].nameWithOwner' | while read repo; do
